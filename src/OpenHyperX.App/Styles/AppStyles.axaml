<Styles xmlns="https://github.com/avaloniaui">
  <Style Selector="Window">
    <Setter Property="FontFamily" Value="Segoe UI" />
    <Setter Property="Foreground" Value="#17202A" />
    <Setter Property="Background" Value="#F5F7FA" />
  </Style>

  <Style Selector="Window.dark">
    <Setter Property="Foreground" Value="#E8EDF3" />
    <Setter Property="Background" Value="#10161D" />
  </Style>

  <Style Selector="Border.topbar">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="BorderBrush" Value="#D8DEE8" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="24,18" />
  </Style>

  <Style Selector="Window.dark Border.topbar">
    <Setter Property="Background" Value="#161E27" />
    <Setter Property="BorderBrush" Value="#2B3846" />
  </Style>

  <Style Selector="Border.panel">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="BorderBrush" Value="#D8DEE8" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="18" />
  </Style>

  <Style Selector="Window.dark Border.panel">
    <Setter Property="Background" Value="#18222C" />
    <Setter Property="BorderBrush" Value="#2D3A48" />
  </Style>

  <Style Selector="Border.badge">
    <Setter Property="Background" Value="#EAF6F1" />
    <Setter Property="BorderBrush" Value="#9ACDBA" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="12,6" />
  </Style>

  <Style Selector="Window.dark Border.badge">
    <Setter Property="Background" Value="#163A35" />
    <Setter Property="BorderBrush" Value="#2E7568" />
  </Style>

  <Style Selector="Border.logo-mark">
    <Setter Property="Width" Value="42" />
    <Setter Property="Height" Value="42" />
    <Setter Property="Background" Value="#050709" />
    <Setter Property="BorderBrush" Value="#D8DEE8" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style Selector="Window.dark Border.logo-mark">
    <Setter Property="BorderBrush" Value="#2D3A48" />
  </Style>

  <Style Selector="Border.protocol-box">
    <Setter Property="Background" Value="#F7F4EA" />
    <Setter Property="BorderBrush" Value="#E1D3A5" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <Style Selector="Window.dark Border.protocol-box">
    <Setter Property="Background" Value="#27251B" />
    <Setter Property="BorderBrush" Value="#5B5130" />
  </Style>

  <Style Selector="StackPanel.setting">
    <Setter Property="MinHeight" Value="92" />
  </Style>

  <Style Selector="TextBlock.app-title">
    <Setter Property="FontSize" Value="22" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.label">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Foreground" Value="#425466" />
  </Style>

  <Style Selector="Window.dark TextBlock.label">
    <Setter Property="Foreground" Value="#AAB7C4" />
  </Style>

  <Style Selector="TextBlock.metric">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="#66788A" />
  </Style>

  <Style Selector="Window.dark TextBlock.muted">
    <Setter Property="Foreground" Value="#A2AFBD" />
  </Style>

  <Style Selector="TextBlock.muted-small">
    <Setter Property="Foreground" Value="#66788A" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <Style Selector="Window.dark TextBlock.muted-small">
    <Setter Property="Foreground" Value="#A2AFBD" />
  </Style>

  <Style Selector="Button">
    <Setter Property="MinHeight" Value="38" />
    <Setter Property="Padding" Value="16,8" />
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="#216B5B" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>
</Styles>
