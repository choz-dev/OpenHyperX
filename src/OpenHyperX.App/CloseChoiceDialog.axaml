<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenHyperX.App.CloseChoiceDialog"
        Title="Close OpenHyperX"
        Width="420"
        Height="220"
        MinWidth="420"
        MinHeight="220"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <Border Padding="24">
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="18">
      <StackPanel Spacing="6">
        <TextBlock Text="Close OpenHyperX" Classes="section-title" />
        <TextBlock Text="Choose what happens when you press close." Classes="muted" TextWrapping="Wrap" />
      </StackPanel>

      <CheckBox Grid.Row="1"
                x:Name="RememberChoiceCheckBox"
                VerticalAlignment="Center"
                Content="Remember my choice"
                IsChecked="True" />

      <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
        <Button Grid.Column="1"
                Content="Cancel"
                IsCancel="True"
                Click="Cancel_Click" />
        <Button Grid.Column="2"
                Content="Close to tray"
                Click="CloseToTray_Click" />
        <Button Grid.Column="3"
                Classes="primary"
                Content="Exit"
                IsDefault="True"
                Click="Exit_Click" />
      </Grid>
    </Grid>
  </Border>
</Window>
